// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Roles {
  ADMIN
  USER
}

model Users {
  id           String         @id @default(uuid())
  firstName    String         @map("first_name")
  lastName     String         @map("last_name")
  email        String         @unique
  password     String
  Sales        Sales[]
  SeasonPasses SeasonPasses[]
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt() @map("updated_at")
  role         Roles          @default(USER)

  @@map("users")
}

model SeasonPasses {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  seasonStartYear Int      @map("season_start_year")
  price           Int
  category        String?
  row             String?
  seat            String?
  User            Users    @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt() @map("updated_at")

  @@unique([userId, seasonStartYear])
  @@map("season_passes")
}

enum Competition {
  CHAMPIONS_LEAGUE
  CHAMPIONSHIP
  FRENCH_CUP
  LEAGUE_CUP
}

model Matches {
  id           String        @id @default(uuid())
  opponentId   String        @map("opponent_id")
  atHome       Boolean       @map("at_home")
  date         DateTime
  competition  Competition
  Sales        Sales[]
  MatchResults MatchResults?
  Opponent     Opponents     @relation(fields: [opponentId], references: [id])

  @@unique([date, opponentId])
  @@map("matches")
}

model Opponents {
  id      String    @id @default(uuid())
  name    String    @unique()
  Matches Matches[]

  @@map("opponents")
}

model MatchResults {
  id      String  @id @default(uuid())
  matchId String  @unique() @map("match_id")
  score   String
  isWin   Boolean @map("is_win")
  Match   Matches @relation(fields: [matchId], references: [id])

  @@map("match_results")
}

enum SaleStatus {
  PENDING
  SOLD
  CANCELLED
}

model Sales {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  matchId     String          @map("match_id")
  listedPrice Int             @map("listed_price")
  profit      Float
  invest      Int             @default(0)
  nbTickets   Int             @map("nb_tickets")
  status      SaleStatus
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  soldAt      DateTime?       @map("sold_at")
  cancelledAt DateTime?       @map("cancelled_at")
  SaleHistory SaleHistories[]
  Match       Matches         @relation(fields: [matchId], references: [id])
  User        Users           @relation(fields: [userId], references: [id])

  @@map("sales")
}

model SaleHistories {
  id          String     @id @default(uuid())
  saleId      String     @map("sale_id")
  listedPrice Int        @map("listed_price")
  profit      Int
  status      SaleStatus
  createdAt   DateTime   @default(now()) @map("created_at")

  Sale Sales @relation(fields: [saleId], references: [id])

  @@index([saleId, createdAt])
  @@map("sale_histories")
}
