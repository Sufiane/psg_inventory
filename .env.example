# Database (local or managed — free tier available on https://aiven.io)
DATABASE_URL=postgresql://user:password@localhost:5432/psg_inventory

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES=1d

# Football Data API (https://www.football-data.org)
FOOTBALL_DATA_API_KEY=your_api_key_here

# Redis (local or managed — free tier available on https://render.com)
# Use rediss:// for TLS connections (e.g. Render)
REDIS_URL=redis://localhost:6379

# Server (optional, defaults to 7777)
PORT=7777
